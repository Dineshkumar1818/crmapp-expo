{
  "expo": {
    "name": "SKTM CRM",
    "slug": "sktm-crm",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./src/assets/images/logo.png",
    "splash": {
      "image": "./src/assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF8F0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to scan barcodes for card numbers.",
        "NSLocationWhenInUseUsageDescription": "This app needs location access to track your journey and save your travel routes.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app needs location access to track your journey even when in background.",
        "NSLocationAlwaysUsageDescription": "This app needs location access to track your journey even when in background.",
        "UIBackgroundModes": ["location", "fetch"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/logo.png",
        "backgroundColor": "#FDF8F0"
      },
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ],
      "package": "com.anonymous.sktmcrm",
      "foregroundService": {
        "notificationTitle": "📍 Location Tracking",
        "notificationBody": "Tracking your journey in background...",
        "notificationColor": "#D4AF37"
      }
    },
    "web": {
      "favicon": "./src/assets/images/logo.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow CRM App to access your camera to scan barcodes.",
          "barcodeScannerEnabled": true
        }
      ],
      [
        "expo-location",
        {
          "isAndroidBackgroundLocationEnabled": true,
          "isIosBackgroundLocationEnabled": true
        }
      ]
    ],
    "platforms": [
      "ios",
      "android",
      "web"
    ]
  }
}